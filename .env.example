## Mailjet (server-side only)
# Create keys in Mailjet account.
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_API_SECRET=your_mailjet_api_secret

## Sender identity (must be a verified sender/domain in Mailjet)
MAILJET_FROM_EMAIL=you@yourdomain.com
MAILJET_FROM_NAME="Shivanichchi & Co."

## Admin recipient (where enquiries should arrive)
MAILJET_ADMIN_EMAIL=admin@yourdomain.com
MAILJET_ADMIN_NAME="Shivanichchi & Co. Admin"

## Server config
PORT=8787
